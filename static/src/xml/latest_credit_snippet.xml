<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="dynamic_snippet.credit_data">
        <section class="categories_section">
            <div class="container">
                <h3 class="section_heading" style="text-align:center">Latest Credits</h3>
                <p class="lead" style="text-align:center">Check out your latest credits in our company !</p>
                <div t-attf-id="#{carousel_id}" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        <t t-foreach="chunks"
                           t-as="chunk"
                           t-key="index">
                                <div t-attf-class="carousel-item #{chunk.is_active ? 'active' : ''}">
                                    <div class="s_dynamic_snippet_row row g-3">
                                        <t t-foreach="chunk" t-as="credit" t-key="credit.id">
                                            <div class="categories col-lg-3">
                                                <div class="img_wrapper">
                                                    <a t-att-href="credit.link">
                                                        <t t-if="credit.image">
                                                            <img t-att-src="'data:image/png;base64,' + credit.image"
                                                                 class="oe_product_image_img h-100 w-100"
                                                                 t-att-alt="credit.recurring_subscription_id or 'Category Image'"
                                                                 loading="lazy"/>
                                                        </t>
                                                        <t t-else="">
                                                            <img src="/recurring_subscription/static/src/img/no_image.png"
                                                                 class="oe_product_image_img h-100 w-100"
                                                                 loading="lazy"/>
                                                        </t>
                                                    </a>
                                                </div>
                                                <div class="type">
                                                    <t t-esc="credit.recurring_subscription_id[1]"/>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                        </t>
                </div>
                <button class="carousel-control-prev"
                        type="button"
                        t-attf-data-bs-target="##{carousel_id}"
                        data-bs-slide="prev">
                    <span class="oi oi-chevron-left ms-md-n4 rounded-pill p-3 bg-700"></span>
                </button>
                <button class="carousel-control-next"
                        type="button"
                        t-attf-data-bs-target="##{carousel_id}"
                        data-bs-slide="next">
                    <span class="oi oi-chevron-right me-md-n4 rounded-pill p-3 bg-700"></span>
                </button>
            </div>
            </div>
        </section>
    </t>
</templates>
