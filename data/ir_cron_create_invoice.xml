<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data noupdate="0">
       <record id="daily_invoice_sent" model="ir.cron">
           <field name="name">Daily Invoice</field>
           <field name="model_id" ref="recurring_subscription.model_recurring_subscription"/>
           <field name="state">code</field>
           <field name="code">model.action_create_invoice()</field>
           <field name="user_id" ref="base.user_root"/>
           <field name='interval_number'>1</field>
           <field name='interval_type'>days</field>
           <field name="nextcall"
                  eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 12:00:00')"/>
           <field name="priority">1</field>
       </record>
   </data>
</odoo>
