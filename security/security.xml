<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_subscription" model="ir.module.category">
            <field name="name">Subscription</field>
            <field name="sequence">5</field>
        </record>

        <record id="groups_privilege_recurring_subscription" model="res.groups.privilege">
            <field name="name">Recurring Subscription</field>
            <field name="sequence">10</field>
            <field name="category_id" ref="module_category_subscription"/>
        </record>

        <record id="group_subscription_user" model="res.groups">
            <field name="name">Subscription Users</field>
            <field name="privilege_id" ref="groups_privilege_recurring_subscription"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Subscription user can bill the subscription from Billing schedule.</field>
        </record>

        <record id="group_subscription_manager" model="res.groups">
            <field name="name">Subscription Managers</field>
            <field name="privilege_id" ref="groups_privilege_recurring_subscription"/>
            <field name="implied_ids" eval="[(4, ref('recurring_subscription.group_subscription_user'))]"/>
            <field name="comment">Subscription manager will have the access to all the records.</field>
        </record>

        <record id="own_company_rule" model="ir.rule">
            <field name="name">own company rule</field>
            <field name="model_id" ref="model_recurring_subscription"/>
            <field name="groups" eval="[Command.set([ref('recurring_subscription.group_subscription_user')])]"/>
            <field name="domain_force">[('company_id.id','in', user.company_ids)]</field>
        </record>
    </data>
</odoo>