<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--    create form view    -->
        <record id="recurring_subscription_report_views_form" model="ir.ui.view">
            <field name="name">subscription.report.wizard.form</field>
            <field name="model">subscription.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Print subscriptions">
                    <group>
                        <field name="subscription_id"/>
                        <field name="recurring_intervals"/>
                    </group>
                    <footer>
                        <button name="action_print_report" type="object" string="Print" class="btn-primary"/>
                        <button string="Cancel" class="btn-primary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <!--    Wizard action sub-->
        <record id="action_recurring_report" model="ir.actions.act_window">
            <field name="name">Subscription Report</field>
            <field name="res_model">subscription.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="recurring_subscription_report_views_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>