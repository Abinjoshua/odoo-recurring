<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Menu Item to link to our new page -->
        <record id="subscription_page_menu" model="website.menu">
            <field name="name">Recurring Subscription</field>
            <field name="url">/recurring-subscription</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence" type="int">99</field>
        </record>

        <template id="recurring_subscription_template" name="Recurring subscription">
            <t t-call="website.layout">
                <div id="wrap">
                    <div class="oe_structure">
                        <div class="container">
                            <form role="form" action="/create/subscription" method="POST">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="form-group">
                                    <label for="name" class="control-label">Name</label>
                                    <input type="text" name="name" t-att-value="name" id="name"
                                           class="form-control" placeholder="e.g. Sub of Netflix" required="required"/>
                                </div>
                                <div class="form-group">
                                    <label for="product_id" class="control-label">Product</label>
                                    <select name="product_id" class="form-control link-style">
                                        <t t-foreach="product_rec" t-as="product">
                                            <option t-att-value="product.id" t-esc="product.name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="establishment" class="control-label">Establishment</label>
                                    <input type="text" name="establishment" t-att-value="establishment"
                                           id="establishment"
                                           class="form-control" required="required"/>
                                </div>
                                <div class="form-group">
                                    <label for="recurring_amount" class="control-label">Recurring Amount</label>
                                    <input type="text" name="recurring_amount" t-att-value="recurring_amount"
                                           id="recurring_amount"
                                           class="form-control" required="required"/>
                                </div>
                                <div class="mb-0 py-2 col-12 s_website_form_submit s_website_form_no_submit_label text-end">
                                    <button type="submit" class="btn btn-primary s_website_form_send">Submit</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        <record id="subscription_thanks" model="website.page">
            <field name="name">Success</field>
            <field name="type">qweb</field>
            <field name="url">/subscription-created-successfully</field>
            <field name="website_published">True</field>
            <field name="key">recurring_subscription.subscription_thanks</field>
            <field name="arch" type="xml">
                <t name="Success" t-name="recurring_subscription.subscription_thanks">
                    <t t-call="website.layout">
                        <div id="wrap">
                            <div class="container">
                                <h1>Success!</h1>
                                <div class="row">
                                    <div class="col-lg-8">
                                        <div class="alert alert-success" role="status">
                                            The Subscription has been created successfully.
                                        </div>
                                        <a href="/">Go to Homepage</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </field>
        </record>
    </data>
</odoo>
