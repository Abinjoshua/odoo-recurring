<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Menu Item to link to our new page -->
        <record id="credit_page_menu" model="website.menu">
            <field name="name">Credit</field>
            <field name="url">/credit</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence" type="int">30</field>
        </record>
        <template id="credit_template" name="Credit">
            <t t-call="website.layout">
                <div id="wrap">
                    <div class="oe_structure">
                        <div class="o_container_small">
                            <br/>
                            <h2 class="text-center">Create a Subscription Credit</h2>
                            <br/>
                            <form role="form" action="/create/credit" method="POST">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div data-name="Field"
                                     class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                     data-type="char" data-translated-name="Recurring Subscription">
                                    <div class="row s_col_no_resize s_col_no_bgcolor">
                                        <label class="col-form-label col-sm-auto s_website_form_label"
                                               style="width: 200px" for="oy5z43z61698">
                                            <span class="s_website_form_label_content">Recurring Subscription</span>
                                            <span class="s_website_form_mark">*</span>
                                        </label>
                                        <div class="col-sm">
                                            <select name="recurring_subscription_id" class="form-control link-style">
                                                <t t-foreach="subscription_rec" t-as="subscription">
                                                    <option t-att-value="subscription.id" t-esc="subscription.name"/>
                                                </t>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div data-name="Field"
                                     class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                     data-type="char" data-translated-name="Credit Amount">
                                    <div class="row s_col_no_resize s_col_no_bgcolor">
                                        <label class="col-form-label col-sm-auto s_website_form_label"
                                               style="width: 200px" for="oy5z43z61698">
                                            <span class="s_website_form_label_content">Credit Amount
                                            </span>
                                            <span class="s_website_form_mark">*</span>
                                        </label>
                                        <div class="col-sm">
                                            <input type="text" name="credit_amount"
                                                   t-att-value="credit_amount" id="credit_amount"
                                                   class="form-control"
                                                   required="required"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-0 py-2 col-12 s_website_form_submit s_website_form_no_submit_label text-end">
                                    <button type="submit" class="btn btn-primary s_website_form_send">Submit</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        <record id="subscription_thanks" model="website.page">
            <field name="name">Success</field>
            <field name="type">qweb</field>
            <field name="url">/subscription-created-successfully</field>
            <field name="website_published">True</field>
            <field name="key">recurring_subscription.subscription_thanks</field>
            <field name="arch" type="xml">
                <t name="Success" t-name="recurring_subscription.subscription_thanks">
                    <t t-call="website.layout">
                        <div id="wrap">
                            <div class="container">
                                <h1>Success!</h1>
                                <div class="row">
                                    <div class="col-lg-8">
                                        <div class="alert alert-success" role="status">
                                            The Subscription Credit has been created successfully.
                                        </div>
                                        <a href="/">Go to Homepage</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </field>
        </record>
    </data>
</odoo>
