<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Form View   -->
    <record id="recurring_partner_account_views_form" model="ir.ui.view">
        <field name="name">recurring.partner.account.views.form</field>
        <field name="model">recurring.partner.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="account"/>
                        <field name="customer_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--    List View   -->
    <record id="recurring_partner_account_views_list" model="ir.ui.view">
        <field name="name">recurring.partner.account.views.list</field>
        <field name="model">recurring.partner.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="account"/>
            </list>
        </field>
    </record>
    <!--    Window Action Sub   -->
    <record id="action_recurring_partner_account" model="ir.actions.act_window">
        <field name="name">Partner</field>
        <field name="res_model">recurring.partner.account</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Credit</p>
        </field>
    </record>
</odoo>