<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    create form view    -->
    <record id="recurring_subscription_views_form" model="ir.ui.view">
        <field name="name">recurring.subscription.views.form</field>
        <field name="model">recurring.subscription</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" invisible="state=='confirm'" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state=='cancel'"/>
                    <button name="action_send_mail" type="object" string="Send Mail" invisible="state!='done'" class="btn-primary"/>
                    <field name="state" widget="statusbar" options="{'clickable':1}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="order" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="customer_id" readonly="0" force_save="1"/>
                            <field name="establishment"/>
                            <field name="next_billing"/>
                            <field name="currency_id"/>
                            <field name="billing_schedule_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="due_date" />
                            <field name="is_lead"/>
                            <field name="product_id"/>
                            <field name="recurring_amount"/>
                            <field name="company_id"/>
                        </group>
                        <notebook>
                            <page string="Subscription Credit">
                                <field name="subscription_credit_ids">
                                    <list editable="bottom">
                                        <field name="recurring_subscription_id"/>
                                        <field name="due_date"/>
                                        <field name="period_date"/>
                                        <field name="state"/>
                                        <field name="credit_amount"/>
                                        <field name="recurring_amount"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Terms and Conditions">
                                <field name="terms_and_conditions"/>
                            </page>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!--    create list view    -->
    <record id="recurring_subscription_views_list" model="ir.ui.view">
        <field name="name">recurring.subscription.views.list</field>
        <field name="model">recurring.subscription</field>
        <field name="arch" type="xml">
            <list>
                <field name="order"/>
                <field name="name"/>
                <field name="establishment"/>
                <field name="date"/>
                <field name="is_lead"/>
                <field name="product_id"/>
                <field name="customer_id"/>
            </list>
        </field>
    </record>
    <!--    search view    -->
    <record id="recurring_subscription_views_search" model="ir.ui.view">
        <field name="name">recurring.subscription.views.search</field>
        <field name="model">recurring.subscription</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="product_id"/>
                <filter name="filter_jio" string="Jio" domain="[('product_id','=','Jio')]"/>
                <filter name="filter_amazon" string="Amazon" domain="[('product_id','=','Amazon')]"/>
                <filter name="filter_netflix" string="Netflix" domain="[('product_id','=','Netflix')]"/>
                <separator string="Group By"/>
                <group>
                    <filter string="Establishment" name="group_by_establishment"
                            context="{'group_by':'establishment'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--    Window action sub-->
    <record id="action_recurring_subscription" model="ir.actions.act_window">
        <field name="name">Subscription</field>
        <field name="res_model">recurring.subscription</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Subscription</p>
        </field>
    </record>
</odoo>