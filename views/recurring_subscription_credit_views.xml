<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Form view-->
    <record id="recurring_subscription_credit_views_form" model="ir.ui.view">
        <field name="name">recurring.subscription.credit.views.form</field>
        <field name="model">recurring.subscription.credit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" options="{'clickable':1}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="recurring_subscription_id"/>
                            <field name="partner_id"/>
                            <field name="recurring_amount"/>
                            <field name="currency_id"/>
                            <field name="company_id"/>
                            <field name="create_date"/>
                        </group>
                        <group>
                            <field name="establishment"/>
                            <field name="due_date"/>
                            <field name="period_date"/>
                            <field name="credit_amount"/>
                            <field name="billing_schedule_id"/>
                            <field name="amount_pending"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!--    create list view    -->
    <record id="recurring_subscription_credit_views_list" model="ir.ui.view">
        <field name="name">recurring.subscription.credit.list</field>
        <field name="model">recurring.subscription.credit</field>
        <field name="arch" type="xml">
            <list>
                <field name="recurring_subscription_id"/>
                <field name="partner_id"/>
                <field name="recurring_amount"/>
                <field name="credit_amount"/>
                <field name="due_date"/>
                <field name="create_date"/>
                <field name="currency_id"/>
            </list>
        </field>
    </record>
    <!--    Window action sub-->
    <record id="action_recurring_subscription_credit" model="ir.actions.act_window">
        <field name="name">Credit</field>
        <field name="res_model">recurring.subscription.credit</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Credit</p>
        </field>
    </record>
</odoo>