<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    create form view-->
    <record id="recurring_billing_schedule_views_form" model="ir.ui.view">
        <field name="name">recurring.billing.schedule.views.form</field>
        <field name="model">recurring.billing.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <!--        smart button section        -->
                    <div name="button_box" position="inside">
                        <button class="oe_stat_button"
                                type="object"
                                icon="fa-outdent"
                                name="action_get_recurring_subscription">
                            <field string="Recurring Subscriptions" name="recurring_subscription_count"
                                   widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="simulation"/>
                            <field name="restrict_customers_ids" widget="many2many_tags"/>
                            <field name="active" invisible="1"/>
                            <field name="recurring_subscription_ids" widget="many2many_tags"/>
                            <field name="total_credit_amount"/>
                        </group>
                        <group>
                            <field name="date_begin" widget="daterange" string="From"
                                   class="oe_inline" options="{'related_end_date': 'date_end'}"/>
                            <field name="date_end" widget="daterange" string="To"
                                   class="oe_inline" options="{'related_start_date': 'date_begin'}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!--    window action billing schedule  -->
    <record id="action_recurring_billing_schedule" model="ir.actions.act_window">
        <field name="name">Billing Schedule</field>
        <field name="res_model">recurring.billing.schedule</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Billing Schedule</p>
        </field>
    </record>
</odoo>