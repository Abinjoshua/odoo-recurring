<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Menu Item to link to our new page -->
        <record id="billing_schedule_page_menu" model="website.menu">
            <field name="name">Billing Schedule</field>
            <field name="url">/billing-schedule</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence" type="int">40</field>
        </record>

        <template id="billing_schedule_template" name="Billing Schedule">
            <t t-call="website.layout">
                <div id="wrap">
                    <div class="oe_structure">
                        <div class="o_container_small">
                            <br/>
                            <h2 class="text-center">Billing Schedule</h2>
                            <br/>
                            <form role="form" action="/create/billing-schedule" method="POST">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div data-name="Field"
                                     class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                     data-type="char" data-translated-name="Name">
                                    <div class="row s_col_no_resize s_col_no_bgcolor">
                                        <label class="col-form-label col-sm-auto s_website_form_label"
                                               style="width: 200px" for="oy5z43z61698">
                                            <span class="s_website_form_label_content">Name</span>
                                            <span class="s_website_form_mark">*</span>
                                        </label>
                                        <div class="col-sm">
                                            <input type="text" name="name" t-att-value="name" id="name"
                                                   class="form-control"
                                                   required="required"/>
                                        </div>
                                    </div>
                                </div>
                                <!--                                <div data-name="Field"-->
                                <!--                                     class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"-->
                                <!--                                     data-type="char" data-translated-name="Recurring Subscription">-->
                                <!--                                    <div class="row s_col_no_resize s_col_no_bgcolor">-->
                                <!--                                        <label class="col-form-label col-sm-auto s_website_form_label"-->
                                <!--                                               style="width: 200px" for="oy5z43z61698">-->
                                <!--                                            <span class="s_website_form_label_content">Recurring Subscription</span>-->
                                <!--                                            <span class="s_website_form_mark">*</span>-->
                                <!--                                        </label>-->
                                <!--                                        <div class="col-sm">-->
                                <!--                                            <select name="recurring_subscription_ids" class="form-control link-style">-->
                                <!--                                                <t t-foreach="subscription_rec" t-as="subscription">-->
                                <!--                                                    <option t-att-value="subscription.id" t-esc="subscription.name"/>-->
                                <!--                                                </t>-->
                                <!--                                            </select>-->
                                <!--                                        </div>-->
                                <!--                                    </div>-->
                                <!--                                </div>-->
                                <div class="form-group mt-3">
                                    <label for="recurring_subscription_ids">Recurring Subscription</label>
                                    <select name="recurring_subscription_ids" id="recurring_subscription_ids"
                                            class="form-control" multiple="multiple">
                                        <t t-foreach="subscription_rec" t-as="subscription">
                                            <option t-att-value="subscription.id">
                                                <t t-esc="subscription.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="mb-0 py-2 col-12 s_website_form_submit s_website_form_no_submit_label text-end">
                                    <button type="submit" class="btn btn-primary s_website_form_send">Submit</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        <record id="billing_schedule_thanks" model="website.page">
            <field name="name">Success</field>
            <field name="type">qweb</field>
            <field name="url">/billing-schedule-created-successfully</field>
            <field name="website_published">True</field>
            <field name="key">recurring_subscription.billing_schedule_thanks</field>
            <field name="arch" type="xml">
                <t name="Success" t-name="recurring_subscription.billing_schedule_thanks">
                    <t t-call="website.layout">
                        <div id="wrap">
                            <div class="container">
                                <h1>Success!</h1>
                                <div class="row">
                                    <div class="col-lg-8">
                                        <div class="alert alert-success" role="status">
                                            The Billing Schedule has been created successfully.
                                        </div>
                                        <a href="/">Go to Homepage</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </field>
        </record>
    </data>
</odoo>
