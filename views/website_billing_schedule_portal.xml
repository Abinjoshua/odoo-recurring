<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--    Inheriting and adding subscription to the my account portal    -->
    <template id="portal_billing_schedule" name="Billing Schedule" inherit_id="portal.portal_my_home"
              customize_show="True" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
            <t t-set="portal_vendor_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/account/static/src/img/bill.svg'"/>
                <t t-set="title">Billing Schedules</t>
                <t t-set="url" t-value="'/view/billing-schedules'"/>
                <t t-set="text">View or edit your billing schedule here.</t>
                <t t-set="placeholder_count" t-value="'invoice_count'"/>
            </t>
        </div>
    </template>
    <!--    Template for the breadcrumbs    -->
    <template id="portal_my_home_menu_billing_schedule"
              name="Portal layout : created billing schedule entries "
              inherit_id="portal.portal_breadcrumbs">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'billing_schedule_creation'"
                class="breadcrumb-item active">
                <span>Billing Schedule</span>
            </li>
        </xpath>
    </template>
    <!-- Template that define the structure of the table that will display the records in the custom menu.-->
    <template id="portal_my_billing_schedules" name="My Billing Schedule">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Subscriptions</t>
            </t>
            <div t-if="not billing_schedules" class="alert alert-warning" role="alert">
                There are currently no billing schedules created for your account.
            </div>
            <t t-if="billing_schedules" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th name="name">Name</th>
                        <th name="recurring_subscription_ids">Recurring Subscription</th>
                        <th name="state">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="billing_schedules" t-as="billing_schedule">
                        <tr>
                            <td>
                                <span t-field="billing_schedule.name"/>
                            </td>
                            <td>
                                <span t-field="billing_schedule.recurring_subscription_ids"/>
                            </td>
                            <td>
                                <span t-if="billing_schedule.state == 'delete_requested' and not request.env.user.has_group('recurring_subscription.group_subscription_manager')"
                                      class="badge rounded-pill text-bg-info">
                                    <i aria-label="confirm_deletion" title="Waiting For Deletion" role="img"/>
                                    <span class="d-none d-md-inline">Waiting For Deletion</span>
                                </span>
                                <a t-elif="billing_schedule.state == 'delete_requested' and request.env.user.has_group('recurring_subscription.group_subscription_manager')"
                                   role="button"
                                   t-att-href="'/delete-billing-schedule/%s' % billing_schedule.id"
                                   class=" btn btn-outline-primary btn-sm"
                                   title="Confirm the delete"
                                >
                                    <i class="oi me-2"/>Confirm Delete
                                </a>
                                <a t-elif="billing_schedule.state != 'delete_requested'"
                                   class="p-2 text-danger"
                                   t-att-href="'/delete-request/billing-schedule/%s' % billing_schedule.id"
                                   role="button"
                                   title="Remove this billing schedule"
                                >
                                    <i class="fa fa-fw fa-trash"/>
                                </a>
                            </td>
                            <td>
                                <a role="button"
                                   t-att-href="'/create/invoice/%s' % billing_schedule.id"
                                   class=" btn btn-outline-primary btn-sm"
                                   title="Create Invoice"
                                >
                                    <i class="oi me-2"/>Create Invoice
                                </a>
                            </td>
                            <td>
                                <a role="button" t-att-href="'/edit/billing-schedule/%s' % billing_schedule.id"
                                   class="btn btn-link p-0 mt-3"
                                   title="Edit this billing schedule">
                                    <i class="fa fa-pencil"/>
                                </a>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>
<!--        Template for editing the existing record    -->
    <template id="billing_schedule_edit_template" name="Subscription Edit">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="oe_structure">
                    <div class="o_container_small">
                        <br/>
                        <form role="form" action="/edit/billing-schedule" method="POST">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="billing_schedule_id" t-att-value="billing_schedule.id"/>
                            <div data-name="Field"
                                 class="mb-3 col-12"
                                 data-type="char" data-translated-name="Name">
                                <div class="row s_col_no_resize s_col_no_bgcolor">
                                    <label class="col-form-label col-sm-auto s_website_form_label"
                                           style="width: 200px" for="oy5z43z61698">
                                        <span class="s_website_form_label_content">Name</span>
                                        <span class="s_website_form_mark">*</span>
                                    </label>
                                    <div class="col-sm">
                                        <input type="text" name="name" t-att-value="billing_schedule.name" id="name"
                                               class="form-control"
                                               required="required"/>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-0 py-2 col-12 text-end">
                                <button type="submit" class="btn btn-primary">Save Changes</button>
                                <a role="button" href="/view/billing-schedules" class="btn btn-secondary">
                                    Discard
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>